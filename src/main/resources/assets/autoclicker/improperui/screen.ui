div #background {
    size: 100%
    background-color: black
    opacity: 0.3
}

div #content {
    size: 400 280
    background-color: #121212
    border-radius: 5
    border-color: orange
    border-thickness: 1
    center: both
    padding: 12

    div #header {
        size: 100% 20
        text-align: center
        inner-text: "&lAutoclicker"
        text-color: orange
        text-scale: 1.2
        margin-bottom: 15
    }

    div #main-layout {
        size: 100% 110
        child-align: grid
        grid-columns: 2

        div #left-side {
            padding: 4
            h4 { inner-text: "&7Left Click"; margin-bottom: 8 }
            
            checkbox #enabled -autoclicker:config.properties:left { size: 8 8 }
            label { inner-text: " Enabled"; text-scale: 0.8 }

            div #gap { size: 100% 4 }

            checkbox #spam -autoclicker:config.properties:left-spam { size: 8 8 }
            label { inner-text: " Spam"; text-scale: 0.8 }

            div #gap { size: 100% 8 }

            slider #cps -autoclicker:config.properties:left-cps { width: 150 }
            label { inner-text: "Speed (CPS)"; text-scale: 0.7; margin-top: 2 }
        }

        div #right-side {
            padding: 4
            h4 { inner-text: "&7Right Click"; margin-bottom: 8 }

            checkbox #enabled -autoclicker:config.properties:right { size: 8 8 }
            label { inner-text: " Enabled"; text-scale: 0.8 }

            div #gap { size: 100% 4 }

            checkbox #spam -autoclicker:config.properties:right-spam { size: 8 8 }
            label { inner-text: " Spam"; text-scale: 0.8 }

            div #gap { size: 100% 8 }

            slider #cps -autoclicker:config.properties:right-cps { width: 150 }
            label { inner-text: "Speed (CPS)"; text-scale: 0.7; margin-top: 2 }
        }
    }

    div #divider {
        size: 95% 1
        background-color: #2A2A2A
        center: horizontal
        margin: 12 0
    }

    div #shared-settings {
        size: 100% 90
        scrollable: true
        padding: 5
        
        child-align: grid
        grid-columns: 1

        label { inner-text: "&6Global Settings"; margin-bottom: 6; text-scale: 0.9 }

        div #row1 {
            child-align: horizontal
            checkbox -autoclicker:config.properties:no-babies { size: 8 8 }
            label { inner-text: " Stop on Baby Entities"; margin-left: 6; text-scale: 0.8 }
        }

        div #row2 {
            child-align: horizontal
            checkbox -autoclicker:config.properties:stop-when-damage { size: 8 8 }
            label { inner-text: " Stop on Damage"; margin-left: 6; text-scale: 0.8 }
        }

        div #row3 {
            child-align: horizontal
            checkbox -autoclicker:config.properties:stop-when-move { size: 8 8 }
            label { inner-text: " Stop on Movement"; margin-left: 6; text-scale: 0.8 }
        }

        div #row4 {
            child-align: horizontal
            checkbox -autoclicker:config.properties:only-when-target { size: 8 8 }
            label { inner-text: " Only when targeting"; margin-left: 6; text-scale: 0.8 }
        }
    }
}